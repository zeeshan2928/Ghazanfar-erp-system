{
  "name": "erp-backend",
  "version": "0.0.1",
  "description": "ERP Backend API",
  "author": "Ghazanfar",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --testPathPattern='(integration|__tests__)' --runInBand",
    "test:unit": "jest --testPathPattern='\\.spec\\.ts$' --exclude='**/(integration|__tests__)/**'",
    "test:all": "npm run test:unit && npm run test:integration",
    "perf:load": "ts-node performance/load-tests.ts",
    "perf:profile:cpu": "ts-node --max-old-space-size=4096 performance/cpu-profile.ts",
    "perf:profile:mem": "ts-node performance/memory-profile.ts",
    "perf:analyze": "ts-node performance/analyze-results.ts",
    "security:check": "npm audit && eslint-plugin-security",
    "seed": "ts-node prisma/seed.ts",
    "seed:reset": "prisma migrate reset --force && ts-node prisma/seed.ts",
    "seed:clean": "prisma migrate reset --force",
    "import:validate": "ts-node scripts/validate-import.ts",
    "import:bills": "ts-node scripts/import-bills.ts",
    "import:customers": "ts-node scripts/import-customers.ts",
    "import:vendors": "ts-node scripts/import-vendors.ts",
    "import:inventory": "ts-node scripts/import-inventory.ts",
    "archive:bills": "ts-node scripts/archive-old-bills.ts",
    "cleanup:all": "ts-node scripts/cleanup-database.ts",
    "data:stats": "ts-node scripts/get-data-stats.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.0.3",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.7.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@playwright/test": "^1.40.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^3.0.13",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "artillery": "^2.0.0",
    "clinic": "^13.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
