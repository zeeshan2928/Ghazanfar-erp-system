generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     Int                    @id @default(autoincrement())
  name                   String                 @unique
  slug                   String                 @unique
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  bills                  Bill[]
  billLines              BillLine[]
  invoiceSequence        InvoiceSequence?
  customers              Customer[]
  gatePasses             GatePass[]
  gatePassItems          GatePassItem[]
  inventories            Inventory[]
  inventoryReservations  InventoryReservation[]
  inventoryMovements     InventoryMovement[]
  inventoryTransfers     InventoryTransfer[]
  inventoryLevels        InventoryLevel[]
  inventoryHolds         InventoryHold[]
  inventoryReconciliations InventoryReconciliation[]
  inventoryWarehouseTransfers InventoryWarehouseTransfer[]
  products               Product[]
  productCategories      ProductCategory[]
  brands                 Brand[]
  purchaseOrders         PurchaseOrder[]
  users                  User[]
  vendors                Vendor[]
  warehouses             Warehouse[]
  warehouseTransfers     WarehouseTransfer[]
  cashBookEntries        CashBookEntry[]
  cashBookMatches        CashBookMatch[] @relation("CashBookMatches")
  bankStatements         BankStatement[]
  cashBookComments       CashBookComment[]
  cashBookApprovals      CashBookApproval[]
  cashBookAudits         CashBookAudit[]
  commissionRules        CommissionRule[]
  commissionCalculations CommissionCalculation[]
  productCommissions     ProductCommission[]
  chartOfAccounts        ChartOfAccount[]
  journalEntries         JournalEntry[]
  glPostings             GLPosting[]
  budgets                Budget[]
  arAgings               ArAging[]
  apAgings               ApAging[]
}

model User {
  id                                    Int               @id @default(autoincrement())
  email                                 String            @unique
  password                              String
  firstName                             String
  lastName                              String
  role                                  UserRole          @default(SALESMAN)
  isActive                              Boolean           @default(true)
  createdAt                             DateTime          @default(now())
  updatedAt                             DateTime          @updatedAt
  organizationId                        Int
  warehouseId                           Int?
  bills_approved                        Bill[]            @relation("ApprovedBy")
  Bill_Bill_created_byToUser            Bill[]            @relation("Bill_created_byToUser")
  bills_modified                        Bill[]            @relation("LastModifiedBy")
  bills_as_salesman                     Bill[]            @relation("Salesman")
  cashBookEntries                       CashBookEntry[]
  cashBookMatchesCreatedBy              CashBookMatch[]   @relation("CashBookMatchesCreatedBy")
  cashBookComments                      CashBookComment[]
  cashBookApprovalsApproved             CashBookApproval[]
  cashBookAudits                        CashBookAudit[]
  inventoryMovements                    InventoryMovement[]
  inventoryTransfersRequested           InventoryTransfer[] @relation("InventoryTransfer_requestedBy")
  inventoryTransfersReceived            InventoryTransfer[] @relation("InventoryTransfer_receivedBy")
  inventoryHoldsCreated                 InventoryHold[] @relation("InventoryHold_createdBy")
  inventoryHoldsApproved                InventoryHold[] @relation("InventoryHold_approvedBy")
  inventoryReconciliationsCounted       InventoryReconciliation[] @relation("InventoryReconciliation_countedBy")
  inventoryReconciliationsApproved      InventoryReconciliation[] @relation("InventoryReconciliation_approvedBy")
  inventoryWarehouseTransfersRequested  InventoryWarehouseTransfer[] @relation("InventoryWarehouseTransfer_requestedBy")
  inventoryWarehouseTransfersApproved   InventoryWarehouseTransfer[] @relation("InventoryWarehouseTransfer_approvedBy")
  commissionCalculations                CommissionCalculation[] @relation("CommissionCalculations")
  commissionApprovals                   CommissionCalculation[] @relation("CommissionApprovals")
  organization                          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Warehouse                             Warehouse?        @relation(fields: [warehouseId], references: [id])
}

model Warehouse {
  id                                                               Int                 @id @default(autoincrement())
  organizationId                                                   Int
  name                                                             String
  slug                                                             String
  location                                                         String
  isActive                                                         Boolean             @default(true)
  createdAt                                                        DateTime            @default(now())
  updatedAt                                                        DateTime            @updatedAt
  gatePasses                                                       GatePass[]
  inventory                                                        Inventory[]
  User                                                             User[]
  organization                                                     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouseTransfersFrom WarehouseTransfer[] @relation("WarehouseTransfer_from")
  warehouseTransfersTo   WarehouseTransfer[] @relation("WarehouseTransfer_to")

  @@unique([organizationId, slug])
}

model Tax {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  rate_percent   Int
  tax_type       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model PurchaseOrder {
  id                     Int                    @id @default(autoincrement())
  organizationId         Int
  po_number              String
  manual_reference       String?
  vendorId               Int
  status                 PurchaseOrderStatus    @default(DRAFT)
  expected_delivery_date DateTime?
  actual_delivery_date   DateTime?
  due_date               DateTime?              // For AP aging calculation
  po_amount              Int                    @default(0)  // Total PO amount in cents
  amount_paid            Int                    @default(0)  // Amount paid in cents
  created_by             Int
  remarks                String?
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor                 Vendor                 @relation(fields: [vendorId], references: [id])
  PurchaseOrderItem      PurchaseOrderItem[]
  PurchaseOrderReceipt   PurchaseOrderReceipt[]
  apAgings               ApAging[]

  @@unique([organizationId, manual_reference])
  @@unique([organizationId, po_number])
  @@index([organizationId, status, createdAt])
  @@index([vendorId, status])
}

model Inventory {
  id                            Int                              @id @default(autoincrement())
  organizationId                Int
  productId                     Int
  warehouseId                   Int
  physical_on_hand              Int                              @default(0)
  reserved                      Int                              @default(0)
  available                     Int                              @default(0)
  opening_balance               Int                              @default(0)
  updatedAt                     DateTime                         @updatedAt
  lastReservedAt                DateTime?                        @db.Timestamp(6)
  createdAt                     DateTime                         @default(now()) @db.Timestamp(6)
  organization                  Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Product                       Product                         @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse                     Warehouse                       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryReservations         InventoryReservation[]
  movements                     InventoryMovement[]
  transfersFrom                 InventoryTransfer[]             @relation("InventoryTransfer_from")
  transfersTo                   InventoryTransfer[]             @relation("InventoryTransfer_to")
  level                         InventoryLevel?
  holds                         InventoryHold[]
  reconciliationItems           InventoryReconciliationItem[]

  @@unique([organizationId, productId, warehouseId])
  @@index([organizationId, warehouseId])
}

model InventoryReservation {
  id             Int          @id @default(autoincrement())
  organizationId Int
  billId         Int
  inventoryId    Int
  quantity       Int
  status         String       @default("RESERVED") // RESERVED, RELEASED, EXPIRED
  releaseType    String?      // AUTO, MANUAL, EXPIRED
  releaseDate    DateTime?
  createdAt      DateTime     @default(now()) @db.Timestamp(6)
  updatedAt      DateTime     @updatedAt
  bill           Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  inventory      Inventory    @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([billId, status])
  @@index([inventoryId, status])
  @@index([organizationId, status, createdAt])
}

model InventoryMovement {
  id               Int                    @id @default(autoincrement())
  organizationId   Int
  inventoryId      Int
  movementType     InventoryMovementType
  quantity         Int
  reference        String?                // PO#, Adjustment#, Transfer#, etc.
  remarks          String?
  createdBy        Int
  createdAt        DateTime               @default(now()) @db.Timestamp(6)
  updatedAt        DateTime               @updatedAt
  inventory        Inventory              @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser    User                   @relation(fields: [createdBy], references: [id])

  @@index([organizationId, createdAt])
  @@index([inventoryId, movementType])
  @@index([createdBy, createdAt])
}

model InventoryTransfer {
  id                Int          @id @default(autoincrement())
  organizationId    Int
  transferNumber    String       @unique
  fromInventoryId   Int
  toInventoryId     Int
  quantity          Int
  status            String       @default("PENDING") // PENDING, IN_TRANSIT, RECEIVED, REJECTED
  requestedBy       Int
  receivedBy        Int?
  requestDate       DateTime     @default(now())
  receivedDate      DateTime?
  remarks           String?
  createdAt         DateTime     @default(now()) @db.Timestamp(6)
  updatedAt         DateTime     @updatedAt
  fromInventory     Inventory    @relation("InventoryTransfer_from", fields: [fromInventoryId], references: [id], onDelete: Cascade)
  toInventory       Inventory    @relation("InventoryTransfer_to", fields: [toInventoryId], references: [id], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedByUser   User         @relation("InventoryTransfer_requestedBy", fields: [requestedBy], references: [id])
  receivedByUser    User?        @relation("InventoryTransfer_receivedBy", fields: [receivedBy], references: [id])

  @@index([organizationId, status])
  @@index([fromInventoryId, toInventoryId])
}

model InventoryLevel {
  id                Int       @id @default(autoincrement())
  organizationId    Int
  inventoryId       Int       @unique
  minimumQuantity   Int       @default(10)
  reorderQuantity   Int       @default(50)
  maximumQuantity   Int?
  safetyStock       Int       @default(0)
  lastReorderDate   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  inventory         Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([inventoryId])
}

model InventoryHold {
  id               Int       @id @default(autoincrement())
  organizationId   Int
  inventoryId      Int
  quantity         Int
  holdType         HoldType
  reason           String?
  createdBy        Int
  approvedBy       Int?
  approvalDate     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  inventory        Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser    User      @relation("InventoryHold_createdBy", fields: [createdBy], references: [id])
  approverUser     User?     @relation("InventoryHold_approvedBy", fields: [approvedBy], references: [id])

  @@index([organizationId, holdType])
  @@index([inventoryId, holdType])
}

model InventoryReconciliation {
  id                  Int                              @id @default(autoincrement())
  organizationId      Int
  reconciliationDate  DateTime
  status              ReconciliationStatus             @default(PENDING)
  countedBy           Int
  approvedBy          Int?
  approvalDate        DateTime?
  remarks             String?
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
  organization        Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  countedByUser       User                            @relation("InventoryReconciliation_countedBy", fields: [countedBy], references: [id])
  approverUser        User?                           @relation("InventoryReconciliation_approvedBy", fields: [approvedBy], references: [id])
  items               InventoryReconciliationItem[]

  @@index([organizationId, reconciliationDate])
  @@index([status])
}

model InventoryReconciliationItem {
  id                   Int                      @id @default(autoincrement())
  reconciliationId     Int
  inventoryId          Int
  systemQuantity       Int
  countedQuantity      Int
  variance             Int
  variancePercentage   Decimal                  @db.Decimal(5, 2)
  adjustmentId         Int?
  remarks              String?
  createdAt            DateTime                 @default(now())
  reconciliation       InventoryReconciliation  @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  inventory            Inventory                @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, inventoryId])
  @@index([reconciliationId])
}

model InventoryWarehouseTransfer {
  id                Int          @id @default(autoincrement())
  organizationId    Int
  transferNumber    String       @unique
  fromBillId        Int?
  toVendorId        Int?
  productId         Int
  quantity          Int
  reason            String
  status            String       @default("PENDING") // PENDING, APPROVED, REJECTED, PROCESSED
  requestedBy       Int
  approvedBy        Int?
  approvalDate      DateTime?
  processedDate     DateTime?
  remarks           String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product           Product      @relation(fields: [productId], references: [id])
  requestedByUser   User         @relation("InventoryWarehouseTransfer_requestedBy", fields: [requestedBy], references: [id])
  approverUser      User?        @relation("InventoryWarehouseTransfer_approvedBy", fields: [approvedBy], references: [id])

  @@index([organizationId, status])
  @@index([productId])
}

model WarehouseTransfer {
  id                                                       Int                     @id @default(autoincrement())
  organizationId                                           Int
  transfer_number                                          String                  @unique
  transfer_date                                            DateTime                @default(now())
  expected_arrival                                         DateTime?
  from_warehouse_id                                        Int
  to_warehouse_id                                          Int
  status                                                   TransferStatus          @default(PENDING)
  received_by                                              Int?
  received_date                                            DateTime?
  remarks                                                  String?
  created_by                                               Int
  createdAt                                                DateTime                @default(now())
  updatedAt                                                DateTime
  from_warehouse                                           Warehouse               @relation("WarehouseTransfer_from", fields: [from_warehouse_id], references: [id])
  organization                                             Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  to_warehouse                                             Warehouse               @relation("WarehouseTransfer_to", fields: [to_warehouse_id], references: [id])
  items                                                    WarehouseTransferItem[]

  @@unique([organizationId, transfer_number])
}

model WarehouseTransferItem {
  id         Int               @id @default(autoincrement())
  transferId Int
  productId  Int
  quantity   Int
  createdAt  DateTime          @default(now()) @db.Timestamp(6)
  transfer   WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId, productId])
}

model Customer {
  id                 Int          @id @default(autoincrement())
  organizationId     Int
  name               String
  phone              String?
  email              String?
  address            String?
  city               String?
  customerType       CustomerType @default(RETAIL)
  creditLimit        Int          @default(0)
  website_account_id String?
  isWebsiteActive    Boolean      @default(false)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  Bill               Bill[]
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, name])
}

model Vendor {
  id             Int             @id @default(autoincrement())
  organizationId Int
  name           String
  email          String?
  phone          String?
  contact_person String?
  address        String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  Product        Product[]
  ProductVendor  ProductVendor[]
  purchaseOrders PurchaseOrder[]
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId, name])
}

model ProductCategory {
  id             Int       @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  products       Product[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Brand {
  id             Int          @id @default(autoincrement())
  organizationId Int
  name           String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  products       Product[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Product {
  id                 Int                 @id @default(autoincrement())
  organizationId     Int
  code               String              @unique
  name               String
  description        String?
  categoryId         Int?
  category           ProductCategory?    @relation(fields: [categoryId], references: [id])
  brandId            Int?
  brand              Brand?              @relation(fields: [brandId], references: [id])
  cost_price         Int                 @default(0)
  isVisibleOnCounter Boolean             @default(true)
  isVisibleOnWebsite Boolean             @default(false)
  isVisibleWholesale Boolean             @default(false)
  isVisibleRetail    Boolean             @default(true)
  base_unit          String              @default("piece")
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  minimum_quantity   Int                 @default(0)
  primary_vendor_id  Int?
  reorder_quantity   Int                 @default(0)
  billLines          BillLine[]
  Inventory          Inventory[]
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Vendor             Vendor?             @relation(fields: [primary_vendor_id], references: [id])
  prices             ProductPrice[]
  vendors            ProductVendor[]
  purchaseHistory    PurchaseHistory[]
  purchaseOrderItems PurchaseOrderItem[]
  warehouseTransfers InventoryWarehouseTransfer[]
  commissions        ProductCommission[]

  @@unique([organizationId, code])
  @@index([organizationId, name])
}

model ProductPrice {
  id            Int          @id @default(autoincrement())
  productId     Int
  channel       Channel
  customerType  CustomerType
  price         Int
  minQuantity   Int          @default(0)
  maxQuantity   Int?
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel, customerType, minQuantity])
  @@index([productId, channel, customerType])
}

model PricingRule {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  conditions     Json
  action         Json
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Bill {
  id                         Int          @id @default(autoincrement())
  organizationId             Int
  bill_number                String
  bill_date                  DateTime     @default(now())
  due_date                   DateTime?    // For AR aging calculation
  amount_paid                Int          @default(0)  // Amount in cents
  customerId                 Int
  channel                    Channel
  website_order_id           String?
  order_source_id            String?
  created_by                 Int
  subtotal                   Int          @default(0)
  discount_amount            Int          @default(0)
  tax_amount                 Int          @default(0)
  total_amount               Int          @default(0)
  payment_method             String?
  remarks                    String?
  status                     OrderStatus  @default(APPROVED)
  isActive                   Boolean      @default(true)
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  salesmanId                 Int          @default(1)
  discountPercentage         Decimal      @default(0) @db.Decimal(5, 2)
  discountType               String?
  deliveryCharges            Int          @default(0)
  cashbookNumber             Int?
  transactionType            String       @default("SALE") // SALE | RETURN
  approvalStatus             String       @default("DRAFT")
  lastModifiedBy             Int?
  approvedBy                 Int?
  approvedAt                 DateTime?    @db.Timestamp(6)
  approvedByUser             User?        @relation("ApprovedBy", fields: [approvedBy], references: [id], onUpdate: NoAction)
  User_Bill_created_byToUser User         @relation("Bill_created_byToUser", fields: [created_by], references: [id])
  customer                   Customer     @relation(fields: [customerId], references: [id])
  lastModifiedByUser         User?        @relation("LastModifiedBy", fields: [lastModifiedBy], references: [id], onUpdate: NoAction)
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesman                   User                   @relation("Salesman", fields: [salesmanId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines                      BillLine[]
  gatePasses                 GatePass[]
  inventoryReservations      InventoryReservation[]
  cashBookEntries            CashBookEntry[]
  cashBookMatches            CashBookMatch[]
  arAgings                   ArAging[]

  @@unique([organizationId, bill_number])
  @@index([organizationId, customerId, bill_date])
}

// Dedicated invoice-number counter, incremented atomically inside the same
// transaction as bill creation. Deliberately NOT derived from sorting/counting
// existing bill_number rows - that approach (used elsewhere in this codebase)
// broke in production on 2026-07-06 when inconsistent historical padding made
// a lexicographic sort pick the wrong "last" row and regenerate a duplicate.
// Format produced: INV-<currentBlock>-<currentCount padded to 5 digits>.
// currentBlock starts at 124 per the business's existing paper/legacy numbering
// and increments every 10,000 invoices (124 -> 125 -> 126 ...).
model InvoiceSequence {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  currentBlock   Int          @default(124)
  currentCount   Int          @default(0)
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BillLine {
  id             Int            @id @default(autoincrement())
  billId         Int
  productId      Int
  warehouseId    Int
  quantity       Int
  unit_price     Int
  tax_id         Int?
  tax_amount     Int            @default(0)
  line_total     Int            @default(0)
  remarks        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organizationId Int            @default(2)
  bill           Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product        Product        @relation(fields: [productId], references: [id])
  gatePassItems  GatePassItem[]

  @@index([billId, productId])
}

model PurchaseHistory {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  productId          Int
  vendor_name        String
  po_number          String
  po_date            DateTime
  quantity_purchased Int
  cost_price         Int
  remarks            String?
  createdAt          DateTime @default(now())
  product            Product  @relation(fields: [productId], references: [id])

  @@index([productId, po_date])
}

model GatePass {
  id               Int            @id @default(autoincrement())
  organizationId   Int
  gate_pass_number String
  gate_pass_date   DateTime       @default(now())
  billId           Int
  warehouseId      Int
  status           GatePassStatus @default(PENDING)
  picked_by        Int?
  picked_date      DateTime?
  confirmed_by     Int?
  confirmed_date   DateTime?
  remarks          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  bill             Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  items            GatePassItem[]

  @@unique([organizationId, gate_pass_number])
  @@index([organizationId, warehouseId, status])
}

model GatePassItem {
  id              Int          @id @default(autoincrement())
  gatePassId      Int
  billLineId      Int
  productId       Int
  quantity        Int
  picked_quantity Int          @default(0)
  organizationId  Int          @default(2)
  billLine        BillLine     @relation(fields: [billLineId], references: [id], onDelete: Cascade)
  gatePass        GatePass     @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([gatePassId, productId])
}

model WebsiteOrder {
  id                    String      @id @default(cuid())
  organizationId        Int
  customer_email        String
  customer_name         String
  customer_phone        String?
  warehouse_id          Int
  items                 Json
  total_amount          Int
  status                OrderStatus @default(PENDING_APPROVAL)
  approval_by           Int?
  approval_date         DateTime?
  rejection_reason      String?
  synced_to_erp_bill_id Int?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([organizationId, status, createdAt])
}

model ProductVendor {
  id                 Int       @id @default(autoincrement())
  productId          Int
  vendorId           Int
  unit_price         Int
  lead_time_days     Int       @default(7)
  last_purchase_date DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor             Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([productId, vendorId])
  @@index([vendorId, productId])
}

model PurchaseOrderItem {
  id                Int           @id @default(autoincrement())
  poId              Int
  productId         Int
  quantity_ordered  Int
  quantity_received Int           @default(0)
  purchaseOrder     PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product           Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([poId, productId])
}

model PurchaseOrderReceipt {
  id                Int           @id @default(autoincrement())
  poId              Int
  productId         Int
  quantity_received Int
  warehouse_id      Int
  status            ReceiptStatus @default(PENDING)
  received_by       Int
  received_date     DateTime      @default(now())
  remarks           String?
  createdAt         DateTime      @default(now())
  purchaseOrder     PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId, productId])
  @@index([warehouse_id, received_date])
}

model CashBookEntry {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  date              DateTime
  amount            Int // in smallest currency unit
  description       String
  category          CashBookCategory
  paymentMethod     PaymentMethod
  referenceNumber   String // cheque #, transaction ID, etc.
  linkedBillId      Int?
  status            CashBookEntryStatus  @default(DRAFT)
  createdBy         Int
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill             Bill?       @relation(fields: [linkedBillId], references: [id], onDelete: SetNull)
  createdByUser    User        @relation(fields: [createdBy], references: [id])
  cashBookMatches  CashBookMatch[]
  comments         CashBookComment[]
  approval         CashBookApproval?
  auditLogs        CashBookAudit[]

  @@unique([organizationId, referenceNumber])
  @@index([organizationId, date])
  @@index([organizationId, category])
  @@index([linkedBillId])
  @@index([createdBy])
}

enum CashBookCategory {
  SALES_RECEIPT
  PURCHASE_PAYMENT
  OPERATING_EXPENSE
  LOAN_PAYMENT
  LOAN_RECEIVED
  EQUIPMENT
  OTHER_INCOME
  OTHER_EXPENSE
}

enum PaymentMethod {
  CASH
  CHEQUE
  BANK_TRANSFER
  MOBILE_MONEY
  CREDIT
}

enum CashBookEntryStatus {
  DRAFT
  POSTED
  RECONCILED
  CANCELLED
}

enum OrderStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  FULFILLED
  CANCELLED
}

enum Channel {
  COUNTER
  WEBSITE
  PHONE
  BULK
}

enum CustomerType {
  INDIVIDUAL
  RETAIL
  WHOLESALE
  CORPORATE
  VIP
  WALK_IN
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  REJECTED
}

enum GatePassStatus {
  PENDING
  PICKED
  CONFIRMED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  REJECTED
  CANCELLED
}

enum ReceiptStatus {
  PENDING
  PARTIAL
  COMPLETE
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
  DAMAGE
  SHRINKAGE
  RETURN
}

enum ReconciliationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
  REJECTED
}

enum HoldType {
  QC_HOLD
  DISPUTE
  DAMAGED_PENDING
  WARRANTY
  LEGAL_HOLD
}

enum UserRole {
  ADMIN
  SALESMAN
  WAREHOUSE
  ACCOUNTANT
  MANAGER
  DATA_ENTRY
}

model CashBookMatch {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  billId            Int
  entryId           Int
  matchedAmount     Int
  reason            String?
  status            CashBookMatchStatus  @default(PENDING)
  createdBy         Int
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization      Organization         @relation("CashBookMatches", fields: [organizationId], references: [id], onDelete: Cascade)
  bill              Bill                 @relation(fields: [billId], references: [id], onDelete: Cascade)
  entry             CashBookEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdByUser     User                 @relation("CashBookMatchesCreatedBy", fields: [createdBy], references: [id])

  @@unique([organizationId, billId, entryId])
  @@index([organizationId, status])
  @@index([billId])
  @@index([entryId])
}

enum CashBookMatchStatus {
  PENDING
  CONFIRMED
  REJECTED
  UNDONE
}

model BankStatement {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  date              DateTime
  description       String
  amount            Int // in smallest currency unit
  referenceNumber   String
  importedAt        DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([organizationId, referenceNumber])
}

model CashBookComment {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  entryId           Int
  author            Int
  content           String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entry             CashBookEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdByUser     User                 @relation(fields: [author], references: [id])

  @@index([organizationId, entryId])
  @@index([entryId])
}

enum CashBookApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model CashBookApproval {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  entryId           Int                  @unique
  status            CashBookApprovalStatus @default(PENDING)
  comments          String?
  approvedBy        Int?
  approvedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entry             CashBookEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  approver          User?                @relation(fields: [approvedBy], references: [id])

  @@index([organizationId, status])
}

enum CashBookAuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  COMMENT_ADDED
}

model CashBookAudit {
  id                Int                  @id @default(autoincrement())
  organizationId    Int
  entryId           Int
  action            CashBookAuditAction
  performedBy       Int
  details           String? // JSON details
  createdAt         DateTime             @default(now())

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entry             CashBookEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  performedByUser   User                 @relation(fields: [performedBy], references: [id])

  @@index([organizationId, entryId])
  @@index([organizationId, createdAt])
}

model CommissionRule {
  id                     Int                    @id @default(autoincrement())
  organizationId         Int
  name                   String
  description            String?
  ruleType               String                 // PERCENTAGE, FIXED, TIERED
  percentage             Decimal?               @db.Decimal(5, 2)
  fixedAmount            Int?
  minSales               Int?
  maxSales               Int?
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  commissionCalculations CommissionCalculation[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model CommissionCalculation {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  ruleId             Int
  salesPersonId      Int
  period             String   // MONTHLY, QUARTERLY, ANNUAL
  startDate          DateTime
  endDate            DateTime
  baseSales          Int
  commissionAmount   Int
  status             String   @default("DRAFT")  // DRAFT, APPROVED, PAID
  approvedBy         Int?
  approvalDate       DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rule               CommissionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesperson        User           @relation("CommissionCalculations", fields: [salesPersonId], references: [id])
  approver           User?          @relation("CommissionApprovals", fields: [approvedBy], references: [id])

  @@index([organizationId, salesPersonId])
  @@index([organizationId, status])
  @@index([ruleId])
}

model ChartOfAccount {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  accountCode       String             // e.g., 1000, 2100, 5000
  accountName       String             // e.g., Cash, Accounts Payable, Sales Revenue
  accountType       AccountType        // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentAccountId   Int?               // For account hierarchy
  isActive          Boolean            @default(true)
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentAccount     ChartOfAccount?    @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts     ChartOfAccount[]   @relation("AccountHierarchy")
  glPostings        GLPosting[]
  journalLines      JournalEntryLine[]
  budgets           Budget[]

  @@unique([organizationId, accountCode])
  @@index([organizationId, accountType])
  @@index([organizationId, isActive])
}

model JournalEntry {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  entryDate         DateTime
  reference         String?            // e.g., INV-001, CHK-123
  description       String
  status            JournalEntryStatus @default(DRAFT)  // DRAFT, POSTED, REVERSED
  postedDate        DateTime?
  reversalEntryId   Int?               @unique  // If this is a reversal
  memo              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines             JournalEntryLine[]
  reversal          JournalEntry?      @relation("Reversal", fields: [reversalEntryId], references: [id])
  reversedBy        JournalEntry?      @relation("Reversal")

  @@index([organizationId, entryDate])
  @@index([organizationId, status])
}

model JournalEntryLine {
  id                Int                @id @default(autoincrement())
  entryId           Int
  accountId         Int
  description       String?
  debitAmount       Int                @default(0)  // Amount in cents
  creditAmount      Int                @default(0)  // Amount in cents
  lineNumber        Int                // Order within entry
  createdAt         DateTime           @default(now())

  entry             JournalEntry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account           ChartOfAccount     @relation(fields: [accountId], references: [id])

  @@unique([entryId, lineNumber])
  @@index([entryId])
  @@index([accountId])
}

model GLPosting {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  accountId         Int
  postingDate       DateTime
  transactionDate   DateTime           // e.g., invoice date
  reference         String?            // e.g., JE-001, INV-123
  debitAmount       Int                @default(0)  // Amount in cents
  creditAmount      Int                @default(0)  // Amount in cents
  balance           Int                @default(0)  // Running balance in cents
  description       String?
  createdAt         DateTime           @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account           ChartOfAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([organizationId, accountId])
  @@index([organizationId, postingDate])
  @@index([accountId, postingDate])
}

model Budget {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  accountId         Int
  fiscalYear        Int                // e.g., 2026
  period            String             // MONTHLY, QUARTERLY, ANNUAL
  budgetAmount      Int                // Amount in cents
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account           ChartOfAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([organizationId, accountId, fiscalYear, period])
  @@index([organizationId, fiscalYear])
}

model ArAging {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  billId            Int?               // FK to bill
  customerId        Int?
  amount            Int                // Amount in cents (outstanding)
  days_overdue      Int
  ageing_bucket     String             // 0-30, 31-60, 61-90, 90+
  as_of_date        DateTime
  createdAt         DateTime           @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill              Bill?              @relation(fields: [billId], references: [id], onDelete: SetNull)

  @@index([organizationId, as_of_date])
  @@index([customerId])
  @@index([billId])
}

model ApAging {
  id                Int                @id @default(autoincrement())
  organizationId    Int
  purchaseOrderId   Int?               // FK to PurchaseOrder
  vendorId          Int?
  amount            Int                // Amount in cents (outstanding)
  days_overdue      Int
  ageing_bucket     String             // 0-30, 31-60, 61-90, 90+
  as_of_date        DateTime
  createdAt         DateTime           @default(now())

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrder     PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([organizationId, as_of_date])
  @@index([vendorId])
  @@index([purchaseOrderId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum NotificationType {
  BILL_APPROVAL
  BILL_PAID
  PAYMENT_DUE
  PO_APPROVAL
  PO_RECEIVED
  PO_DELAYED
  INVENTORY_LOW
  GENERAL
}

model ProductCommission {
  id              Int       @id @default(autoincrement())
  organizationId  Int
  productId       Int
  commissionRate  Decimal   @db.Decimal(5, 2)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId, effectiveFrom])
  @@index([organizationId, productId])
}
