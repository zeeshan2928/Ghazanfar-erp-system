model Product {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  code               String   @unique
  name               String
  description        String?
  categoryId         Int?
  costPrice          Int      @default(0)
  isVisibleOnCounter Boolean  @default(true)
  isVisibleOnWebsite Boolean  @default(false)
  isVisibleWholesale Boolean  @default(false)
  isVisibleRetail    Boolean  @default(true)
  baseUnit           String   @default("piece")
  minimumQuantity    Int      @default(0)
  reorderQuantity    Int      @default(0)
  primaryVendorId    Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryVendor      Vendor?             @relation("PrimaryVendor", fields: [primaryVendorId], references: [id])
  prices             ProductPrice[]
  billLines          BillLine[]
  purchaseHistory    PurchaseHistory[]
  vendors            ProductVendor[]
  purchaseOrderItems PurchaseOrderItem[]
  ProductCommission  ProductCommission[]

  @@unique([organizationId, code])
  @@index([organizationId, name])
}

model ProductPrice {
  id             Int       @id @default(autoincrement())
  organizationId Int
  productId      Int
  channel        String
  customerType   String
  price          Int
  minQuantity    Int       @default(0)
  maxQuantity    Int?
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel, customerType, minQuantity])
  @@index([productId])
}

model PricingRule {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  conditions     Json
  action         Json
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Bill {
  id             Int      @id @default(autoincrement())
  organizationId Int
  billNumber     String
  cashbookNumber Int?
  billDate       DateTime @default(now())
  customerId     Int
  salesmanId     Int // MANDATORY - for commission
  channel        String
  websiteOrderId String?
  orderSourceId  String?

  createdBy      Int
  lastModifiedBy Int?
  approvedBy     Int?

  subtotal           Int           @default(0)
  discountType       DiscountType?
  discountAmount     Int           @default(0)
  discountPercentage Decimal       @db.Decimal(5, 2)
  deliveryCharges    Int           @default(0)
  taxAmount          Int           @default(0)
  totalAmount        Int           @default(0)

  paymentMethod String? // CASH, ONLINE, CHECK, CREDIT
  remarks       String?

  status         String                @default("APPROVED")
  approvalStatus InvoiceApprovalStatus @default(DRAFT)

  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer           Customer     @relation(fields: [customerId], references: [id])
  createdByUser      User         @relation("CreatedBy", fields: [createdBy], references: [id])
  lastModifiedByUser User?        @relation("LastModifiedBy", fields: [lastModifiedBy], references: [id])
  approvedByUser     User?        @relation("ApprovedBy", fields: [approvedBy], references: [id])
  salesman           User         @relation("Salesman", fields: [salesmanId], references: [id])

  lines         BillLine[]
  gatePasses    GatePass[]
  modifications InvoiceModification[]
  commissions   CommissionTransaction[] @relation("InvoiceCommissions")
  reservations  InventoryReservation[] @relation("BillReservations")

  @@unique([organizationId, billNumber])
  @@index([organizationId, customerId, billDate])
  @@index([salesmanId])
  @@index([approvalStatus])
  @@index([createdBy])
}

model BillLine {
  id             Int      @id @default(autoincrement())
  organizationId Int
  billId         Int
  productId      Int
  warehouseId    Int
  quantity       Int
  unitPrice      Int
  taxId          Int?
  taxAmount      Int      @default(0)
  lineTotal      Int      @default(0)
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill          Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  gatePassItems GatePassItem[]

  @@index([billId, productId])
}

model PurchaseHistory {
  id                Int      @id @default(autoincrement())
  organizationId    Int
  productId         Int
  vendorName        String
  poNumber          String
  poDate            DateTime
  quantityPurchased Int
  costPrice         Int
  remarks           String?
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@index([productId, poDate])
}

model GatePass {
  id             Int       @id @default(autoincrement())
  organizationId Int
  gatePassNumber String
  gatePassDate   DateTime  @default(now())
  billId         Int
  warehouseId    Int
  status         String    @default("PENDING")
  pickedBy       Int?
  pickedDate     DateTime?
  confirmedBy    Int?
  confirmedDate  DateTime?
  remarks        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill         Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id])
  items        GatePassItem[]
  reservations InventoryReservation[] @relation("GatePassReservations")

  @@unique([organizationId, gatePassNumber])
  @@index([organizationId, warehouseId])
}

model GatePassItem {
  id             Int @id @default(autoincrement())
  organizationId Int
  gatePassId     Int
  billLineId     Int
  productId      Int
  quantity       Int
  pickedQuantity Int @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gatePass     GatePass     @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  billLine     BillLine     @relation(fields: [billLineId], references: [id], onDelete: Cascade)

  @@index([gatePassId, productId])
}

model InventoryReservation {
  id            Int       @id @default(autoincrement())
  organizationId Int
  billId        Int
  inventoryId   Int
  gatePassId    Int?
  quantity      Int
  status        String    @default("RESERVED") // RESERVED, RELEASED, EXPIRED
  releaseType   String    @default("AUTO") // AUTO, MANUAL, EXPIRED
  releaseDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill         Bill         @relation("BillReservations", fields: [billId], references: [id], onDelete: Cascade)
  inventory    Inventory    @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  gatePass     GatePass?    @relation("GatePassReservations", fields: [gatePassId], references: [id], onDelete: SetNull)

  @@unique([billId, inventoryId])
  @@index([organizationId, status])
  @@index([billId, status])
  @@index([inventoryId, status])
}

model WebsiteOrder {
