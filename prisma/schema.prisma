generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================================
//                            ENUMS
// ================================================================================

enum OrderStatus {
  DRAFT
  APPROVED
  PENDING_APPROVAL
  REJECTED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Channel {
  COUNTER
  WHOLESALE
  RETAIL
  WEBSITE
}

enum CustomerType {
  RETAIL
  WHOLESALE
  WALKIN
}

enum TransferStatus {
  PENDING
  SHIPPED
  RECEIVED
}

enum GatePassStatus {
  PENDING
  PICKED
  CONFIRMED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  REJECTED
  CANCELLED
}

enum ReceiptStatus {
  PENDING
  PARTIAL
  COMPLETE
}

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  SALESMAN
  WAREHOUSE_STAFF
  STAFF
  LABOUR_STAFF
  VIEWER
}

enum CommissionType {
  PER_PRODUCT
  PER_INVOICE
  TIERED
}

enum TargetStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
}

enum SalesImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum LeaveType {
  CASUAL
  SICK
  ANNUAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALFDAY
}

enum BonusStatus {
  CALCULATED
  APPROVED
  PAID
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum AuditAction {
  INVOICE_APPROVED
  COMMISSION_APPROVED
  DISCOUNT_APPLIED
  ADJUSTMENT_MADE
  REFUND_PROCESSED
  WRITE_OFF
  MODIFICATION_REQUEST_CREATED
  MODIFICATION_APPROVED
  BILL_PRINTED
  GATE_PASS_PRINTED
}

// ================================================================================
//                    MASTER MODELS (Organization & User)
// ================================================================================

model Organization {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // HEAD 1: SALES
  users      User[]
  orders     Order[]
  orderItems OrderItem[]
  payments   Payment[]
  discounts  Discount[]
  taxes      Tax[]
  shippings  Shipping[]
  returns    Return[]

  // HEAD 2: PURCHASING
  purchaseOrders     PurchaseOrder[]
  poItems            POItem[]
  goodsReceipts      GoodsReceipt[]
  vendorInvoices     VendorInvoice[]
  vendorPayments     VendorPayment[]
  purchaseReturns    PurchaseReturn[]
  reorderManagements ReorderManagement[]

  // HEAD 3: INVENTORY
  inventories            Inventory[]
  warehouseTransfers     WarehouseTransfer[]
  warehouseTransferItems WarehouseTransferItem[]
  stockAdjustments       StockAdjustment[]
  stockMovementLogs      StockMovementLog[]
  reorderPoints          ReorderPoint[]
  physicalStockAudits    PhysicalStockAudit[]
  stockPerformances      StockPerformance[]

  // HEAD 4: ACCOUNTS
  bankAccounts           BankAccount[]
  paymentMethods         PaymentMethod[]
  ledgers                Ledger[]
  journalEntries         JournalEntry[]
  expenseCategories      ExpenseCategory[]
  expenses               Expense[]
  jvPaymentTrackings     JVPaymentTracking[]
  paymentReconciliations PaymentReconciliation[]
  creditLimits           CreditLimit[]
  invoicePaymentMappings InvoicePaymentMapping[]
  agingReports           AgingReport[]
  profitLossReports      ProfitLossReport[]
  balanceSheets          BalanceSheet[]

  // HEAD 5: WALKIN_RETAIL
  walkinOrders         WalkinOrder[]
  walkinItems          WalkinItem[]
  walkinCustomers      WalkinCustomer[]
  walkinCashRegisters  WalkinCashRegister[]
  walkinReturns        WalkinReturn[]
  walkinDiscounts      WalkinDiscount[]
  walkinPaymentMethods WalkinPaymentMethod[]

  // HEAD 6: CUSTOMERS
  customers                 Customer[]
  customerCategories        CustomerCategory[]
  customerCreditLimits      CustomerCreditLimit[]
  customerHistories         CustomerHistory[]
  customerPreferences       CustomerPreference[]
  customerCommunicationLogs CustomerCommunicationLog[]
  customerAnalytics         CustomerAnalytic[]
  customerProductPurchases  CustomerProductPurchase[]
  customerTargets           CustomerTarget[]
  customerIncentives        CustomerIncentive[]

  // HEAD 7: VENDORS
  vendors                 Vendor[]
  vendorCategories        VendorCategory[]
  vendorPaymentTerms      VendorPaymentTerm[]
  vendorPricingHistories  VendorPricingHistory[]
  vendorPerformances      VendorPerformance[]
  vendorProducts          VendorProduct[]
  vendorCommunicationLogs VendorCommunicationLog[]
  vendorQualityIssues     VendorQualityIssue[]
  vendorDeliveryLogs      VendorDeliveryLog[]
  vendorOutstandings      VendorOutstanding[]
  vendorAgreements        VendorAgreement[]
  vendorAlternatives      VendorAlternative[]
  vendorDisputes          VendorDispute[]

  // HEAD 8: OPERATIONS
  warehouses              Warehouse[]
  warehouseLocations      WarehouseLocation[]
  stockPickings           StockPicking[]
  packings                Packing[]
  deliveryTrackings       DeliveryTracking[]
  employeeTaskAssignments EmployeeTaskAssignment[]
  qcInspections           QCInspection[]
  shipmentManifests       ShipmentManifest[]

  // HEAD 9: HR_PAYROLL
  employees               Employee[]
  salaryStructures        SalaryStructure[]
  attendances             Attendance[]
  payrollProcessings      PayrollProcessing[]
  leaveManagements        LeaveManagement[]
  performanceRatings      PerformanceRating[]
  complianceDocuments     ComplianceDocument[]
  commissionRules         CommissionRule[]
  // Sales target management moved to User model (Phase 6)
  commissionCalculations  CommissionCalculation[]
  // salesDataImports moved to ExternalSalesImport with User relationship (Phase 6)
  labourPerformanceRules  LabourPerformanceRule[]
  attendanceBonuses       AttendanceBonus[]
  leaveDeductions         LeaveDeduction[]
  roleBasedAccessControls RoleBasedAccessControl[]
  roleAssignments         RoleAssignment[]
  accessLogs              AccessLog[]

  // HEAD 10: REPORTS_ANALYTICS
  salesDashboardDatas     SalesDashboardData[]
  customerDashboardDatas  CustomerDashboardData[]
  inventoryDashboardDatas InventoryDashboardData[]
  purchaseDashboardDatas  PurchaseDashboardData[]
  accountsDashboardDatas  AccountsDashboardData[]
  vendorDashboardDatas    VendorDashboardData[]
  employeeDashboardDatas  EmployeeDashboardData[]
  comparisonDatas         ComparisonData[]
  kpiMetrics              KPIMetric[]
  dashboardPreferences    DashboardPreference[]
  reportTemplates         ReportTemplate[]
  reportSchedules         ReportSchedule[]
  reportExports           ReportExport[]
  dashboardAuditLogs      DashboardAuditLog[]
  customReports           CustomReport[]
  purchaseHistories       PurchaseHistory[]
  billLines               BillLine[]
  bills                   Bill[]
  gatePasses              GatePass[]
  gatePassItems           GatePassItem[]
  websiteOrders           WebsiteOrder[]
  pricingRules            PricingRule[]
  productVendors          ProductVendor[]
  products                Product[]
  productPrices           ProductPrice[]
  PurchaseOrderItem       PurchaseOrderItem[]
  PurchaseOrderReceipt    PurchaseOrderReceipt[]

  // ADVANCED FEATURES
  notifications           Notification[]
  notificationTemplates   NotificationTemplate[]
  notificationLogs        NotificationLog[]
  notificationPreferences NotificationPreference[]
  auditLogs               AuditLog[]
  emailTemplates          EmailTemplate[]
  emailLogs               EmailLog[]
  userRoleAssignments     UserRoleAssignment[]
  fieldPermissions        FieldPermission[]

  // PHASE 1: INVOICE SYSTEM
  invoiceModifications   InvoiceModification[]
  documentPrintHistories DocumentPrintHistory[]
  commissionTransactions CommissionTransaction[]

  // PHASE 6: SALES COMMISSION & TARGET MANAGEMENT
  productCommissions      ProductCommission[]
  salesTargets_org        SalesTarget[]            @relation("OrgTargets")
  salesPerformanceMetrics SalesPerformanceMetric[]
  externalSalesImports    ExternalSalesImport[]
  SalesDataImport         SalesDataImport[]

  // TIER 1 CRITICAL: WAREHOUSE FULFILLMENT
  inventoryReservations   InventoryReservation[]

  @@index([isActive])
}

model Employee {
  id             Int       @id @default(autoincrement())
  organizationId Int
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  department     String?
  position       String?
  joiningDate    DateTime?
  salary         Decimal?  @db.Decimal(15, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  EmployeeTaskAssignment EmployeeTaskAssignment[]
  SalaryStructure        SalaryStructure[]
  Attendance             Attendance[]
  LeaveManagement        LeaveManagement[]
  PerformanceRating      PerformanceRating[]
  ComplianceDocument     ComplianceDocument[]
  // SalesTarget moved to User model (Phase 6)
  CommissionCalculation  CommissionCalculation[]
  AttendanceBonus        AttendanceBonus[]
  LeaveDeduction         LeaveDeduction[]
  RoleAssignment         RoleAssignment[]
  AccessLog              AccessLog[]

  @@index([organizationId])
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  password       String
  firstName      String?
  lastName       String?
  phone          String?
  organizationId Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Invoice relationships
  bills_created     Bill[] @relation("CreatedBy")
  bills_modified    Bill[] @relation("LastModifiedBy")
  bills_approved    Bill[] @relation("ApprovedBy")
  bills_as_salesman Bill[] @relation("Salesman")

  // Commission relationships
  commissions_earned  CommissionTransaction[] @relation("SalesmanCommissions")
  product_commissions ProductCommission[]     @relation("SalesmanCommissions")
  sales_targets       SalesTarget[]           @relation("SalesTargets")
  targets_assigned_by SalesTarget[]           @relation("TargetsAssignedBy")

  // Audit relationships
  invoice_modifications_by InvoiceModification[]  @relation("ModifiedBy")
  invoice_approvals_by     InvoiceModification[]  @relation("ApprovedBy")
  print_history_by         DocumentPrintHistory[]

  // Import relationships
  sales_imports ExternalSalesImport[]

  @@index([organizationId])
  @@index([email])
}

model Warehouse {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  location       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventory     Inventory[]
  transfersFrom WarehouseTransfer[] @relation("FromWarehouse")
  transfersTo   WarehouseTransfer[] @relation("ToWarehouse")
  gatePasses    GatePass[]

  @@index([organizationId])
}

// ================================================================================
//                        HEAD 1: SALES (7 Tables)
// ================================================================================

model Order {
  id             Int      @id @default(autoincrement())
  organizationId Int
  billNumber     String
  customerId     Int?
  billDate       DateTime
  totalAmount    Decimal  @default(0) @db.Decimal(15, 2)
  status         String   @default("DRAFT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  discounts    Discount[]
  taxes        Tax[]
  shippings    Shipping[]
  returns      Return[]

  @@index([organizationId, billDate])
  @@index([organizationId, customerId])
}

model OrderItem {
  id             Int      @id @default(autoincrement())
  organizationId Int
  orderId        Int
  productId      Int?
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  discountType   String?
  taxAmount      Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal      Decimal  @default(0) @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id             Int      @id @default(autoincrement())
  organizationId Int
  orderId        Int
  paymentAmount  Decimal  @db.Decimal(15, 2)
  paymentDate    DateTime
  paymentMethod  String?
  bankAccountId  Int?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Discount {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  orderId            Int
  discountAmount     Decimal? @db.Decimal(10, 2)
  discountPercentage Decimal? @db.Decimal(5, 2)
  discountReason     String?
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Tax {
  id             Int      @id @default(autoincrement())
  organizationId Int
  orderId        Int
  taxAmount      Decimal  @db.Decimal(10, 2)
  taxType        String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Shipping {
  id              Int       @id @default(autoincrement())
  organizationId  Int
  orderId         Int
  deliveryAddress String?
  deliveryDate    DateTime?
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Return {
  id             Int      @id @default(autoincrement())
  organizationId Int
  orderId        Int
  returnedItem   String?
  quantity       Int?
  reason         String?
  refundAmount   Decimal? @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ================================================================================
//                      HEAD 2: PURCHASING (7 Tables)
// ================================================================================

model PurchaseOrder {
  id             Int      @id @default(autoincrement())
  organizationId Int
  poNumber       String
  vendorId       Int?
  poDate         DateTime
  totalAmount    Decimal  @default(0) @db.Decimal(15, 2)
  status         String   @default("DRAFT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor               Vendor?                @relation(fields: [vendorId], references: [id])
  items                POItem[]
  goodsReceipts        GoodsReceipt[]
  invoices             VendorInvoice[]
  returns              PurchaseReturn[]
  PurchaseOrderItem    PurchaseOrderItem[]
  PurchaseOrderReceipt PurchaseOrderReceipt[]

  @@index([organizationId, poDate])
  @@index([organizationId, vendorId])
}

model POItem {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  poId            Int
  productId       Int?
  quantityOrdered Int
  unitPrice       Decimal? @db.Decimal(12, 2)
  lineTotal       Decimal  @default(0) @db.Decimal(15, 2)
  createdAt       DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}

model GoodsReceipt {
  id               Int      @id @default(autoincrement())
  organizationId   Int
  poId             Int
  quantityReceived Int
  receivedDate     DateTime
  inspectionStatus String?
  createdAt        DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
}

model VendorInvoice {
  id             Int      @id @default(autoincrement())
  organizationId Int
  poId           Int?
  vendorId       Int?
  invoiceNumber  String
  invoiceDate    DateTime
  amount         Decimal? @db.Decimal(15, 2)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  po           PurchaseOrder?  @relation(fields: [poId], references: [id])
  vendor       Vendor?         @relation(fields: [vendorId], references: [id])
  payments     VendorPayment[]
}

model VendorPayment {
  id             Int      @id @default(autoincrement())
  organizationId Int
  vendorId       Int?
  invoiceId      Int?
  paymentAmount  Decimal  @db.Decimal(15, 2)
  paymentDate    DateTime
  paymentMethod  String?
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?        @relation(fields: [vendorId], references: [id])
  invoice      VendorInvoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PurchaseReturn {
  id             Int      @id @default(autoincrement())
  organizationId Int
  poId           Int?
  itemReturned   String?
  quantity       Int?
  reason         String?
  creditAmount   Decimal? @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  po           PurchaseOrder? @relation(fields: [poId], references: [id])
}

model ReorderManagement {
  id                 Int       @id @default(autoincrement())
  organizationId     Int
  productId          Int?
  minimumStockLevel  Int?
  reorderQuantity    Int?
  autoTriggerEnabled Boolean   @default(false)
  lastReorderDate    DateTime?
  createdAt          DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ================================================================================
//                      HEAD 3: INVENTORY (7 Tables)
// ================================================================================

model Inventory {
  id             Int      @id @default(autoincrement())
  organizationId Int
  productId      Int?
  warehouseId    Int?
  physicalOnHand Int      @default(0)
  reserved       Int      @default(0)
  available      Int      @default(0)
  openingBalance Int      @default(0)
  lastReservedAt DateTime?
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?          @relation(fields: [warehouseId], references: [id])
  movements    StockMovementLog[]
  adjustments  StockAdjustment[]
  transfers    WarehouseTransfer[]
  reservations InventoryReservation[]

  @@unique([organizationId, productId, warehouseId])
  @@index([organizationId, productId])
  @@index([organizationId, warehouseId])
}

model WarehouseTransfer {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  fromWarehouseId Int?
  toWarehouseId   Int?
  productId       Int?
  quantity        Int
  transferDate    DateTime
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  inventoryId     Int?

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse?              @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?              @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  inventory     Inventory?              @relation(fields: [inventoryId], references: [id])
  items         WarehouseTransferItem[]
}

model WarehouseTransferItem {
  id             Int               @id @default(autoincrement())
  transferId     Int
  productId      Int
  quantity       Int
  transfer       WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  Organization   Organization?     @relation(fields: [organizationId], references: [id])
  organizationId Int?

  @@index([transferId, productId])
}

model StockAdjustment {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  productId          Int?
  warehouseId        Int?
  quantityDifference Int
  reason             String?
  adjustmentDate     DateTime
  createdAt          DateTime @default(now())
  inventoryId        Int?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventory    Inventory?   @relation(fields: [inventoryId], references: [id])
}

model StockMovementLog {
  id             Int      @id @default(autoincrement())
  organizationId Int
  productId      Int?
  warehouseId    Int?
  movementType   String?
  quantity       Int
  referenceId    Int?
  referenceType  String?
  timestamp      DateTime @default(now())
  inventoryId    Int?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventory    Inventory?   @relation(fields: [inventoryId], references: [id])

  @@index([productId, timestamp])
}

model ReorderPoint {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  productId       Int?
  minimumLevel    Int?
  maximumLevel    Int?
  reorderQuantity Int?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PhysicalStockAudit {
  id               Int      @id @default(autoincrement())
  organizationId   Int
  warehouseId      Int?
  auditDate        DateTime
  productId        Int?
  expectedQuantity Int?
  actualQuantity   Int?
  variance         Int?
  notes            String?
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model StockPerformance {
  id                 Int       @id @default(autoincrement())
  organizationId     Int
  productId          Int?
  lastSaleDate       DateTime?
  daysSinceLastSale  Int?
  salesVelocity      Decimal?  @db.Decimal(10, 2)
  alertStatus        String?
  deadStockThreshold Int       @default(45)
  notificationFlag   Boolean   @default(false)
  updatedAt          DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, alertStatus])
}

// ================================================================================
//                      HEAD 4: ACCOUNTS (13 Tables)
// ================================================================================

model BankAccount {
  id                Int      @id @default(autoincrement())
  organizationId    Int
  accountType       String?
  bankName          String?
  accountNumber     String?
  accountHolderName String?
  currentBalance    Decimal  @default(0) @db.Decimal(18, 2)
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id             Int      @id @default(autoincrement())
  organizationId Int
  type           String?
  description    String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Ledger {
  id             Int      @id @default(autoincrement())
  organizationId Int
  ledgerDate     DateTime
  description    String?
  debitAmount    Decimal  @default(0) @db.Decimal(15, 2)
  creditAmount   Decimal  @default(0) @db.Decimal(15, 2)
  balance        Decimal? @db.Decimal(18, 2)
  categoryId     Int?
  referenceType  String?
  referenceId    Int?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, ledgerDate])
}

model JournalEntry {
  id             Int      @id @default(autoincrement())
  organizationId Int
  entryDate      DateTime
  debitAccount   Int?
  creditAccount  Int?
  amount         Decimal  @db.Decimal(15, 2)
  description    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id             Int      @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  budgetAmount   Decimal? @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     Expense[]
}

model Expense {
  id             Int      @id @default(autoincrement())
  organizationId Int
  expenseDate    DateTime
  categoryId     Int?
  amount         Decimal  @db.Decimal(15, 2)
  description    String?
  approvedBy     Int?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory? @relation(fields: [categoryId], references: [id])
}

model JVPaymentTracking {
  id               Int       @id @default(autoincrement())
  organizationId   Int
  customerId       Int?
  vendorId         Int?
  amount           Decimal   @db.Decimal(15, 2)
  paymentDate      DateTime
  receiptStatus    String    @default("PENDING")
  verificationDate DateTime?
  settlementStatus String    @default("PENDING")
  settlementDate   DateTime?
  createdAt        DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, settlementStatus])
}

