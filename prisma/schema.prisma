  organizationId Int
  userId         Int
  role           UserRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
}

model FieldPermission {
  id                Int      @id @default(autoincrement())
  organizationId    Int
  entity            String // "Bill", "PurchaseOrder", etc.
  field             String // "billAmount", "costPrice", etc.
  role              UserRole
  canRead           Boolean  @default(true)
  canWrite          Boolean  @default(true)
  maskSensitiveData Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entity, field, role])
  @@index([organizationId, entity, role])
}

// ================================================================================
//                    SALES COMMISSION & TARGET MANAGEMENT
// ================================================================================

model ProductCommission {
  id             Int @id @default(autoincrement())
  organizationId Int
  productId      Int
  salesmanId     Int

  commissionType       CommissionType // PER_PRODUCT, PER_INVOICE, TIERED
  commissionAmount     Decimal        @default(0) // Fixed amount in paisa
  commissionPercentage Decimal        @default(0) // Percentage (0-100)

  minQuantity Int? // For tiered: minimum quantity
  maxQuantity Int? // For tiered: maximum quantity

  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesman     User         @relation("SalesmanCommissions", fields: [salesmanId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId, salesmanId, commissionType])
  @@index([salesmanId, isActive])
  @@index([productId, isActive])
  @@index([organizationId, startDate, endDate])
}

model SalesTarget {
  id             Int @id @default(autoincrement())
  organizationId Int
  salesmanId     Int

  targetMonth    Int // 1-12
  targetYear     Int // 2026, etc.
  targetAmount   Decimal // Target in paisa
  targetQuantity Int? // Optional quantity target

  status TargetStatus @default(ACTIVE)

  notes      String?
  assignedBy Int?
  assignedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization            @relation("OrgTargets", fields: [organizationId], references: [id], onDelete: Cascade)
  salesman       User                    @relation("SalesTargets", fields: [salesmanId], references: [id], onDelete: Cascade)
  assignedByUser User?                   @relation("TargetsAssignedBy", fields: [assignedBy], references: [id])
  performance    SalesPerformanceMetric?

  @@unique([organizationId, salesmanId, targetMonth, targetYear])
  @@index([salesmanId, status])
  @@index([organizationId, targetYear, targetMonth])
}

model SalesPerformanceMetric {
  id             Int @id @default(autoincrement())
  organizationId Int
  targetId       Int @unique

  totalSalesAmount Decimal @default(0) // Cumulative sales in paisa
  totalInvoices    Int     @default(0) // Number of invoices
  totalQuantity    Int     @default(0) // Total quantity sold
  totalCommission  Decimal @default(0) // Total commission earned

  progressPercentage Decimal @default(0) // (totalSalesAmount / targetAmount) * 100
  daysInPeriod       Int     @default(0)
  daysRemaining      Int     @default(0)

  lastUpdated DateTime @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  target       SalesTarget  @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([organizationId, lastUpdated])
  @@index([targetId])
}

model ExternalSalesImport {
  id             Int @id @default(autoincrement())
  organizationId Int

  filename     String
  importStatus SalesImportStatus @default(PENDING)

  totalRecords      Int @default(0)
  successfulRecords Int @default(0)
  failedRecords     Int @default(0)

  rawData    String? // JSON: raw imported data
  parsedData String? // JSON: parsed/processed data
  errorLog   String? // JSON: error details

  importedBy Int?
  importedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedByUser User?        @relation(fields: [importedBy], references: [id])

  @@index([organizationId, importStatus])
  @@index([importedAt])
}
