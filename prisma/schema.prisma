// Per-salesman, per-product commission assignment with a quantity target
// for a given period - distinct from ProductCommission (store-wide rate)
// and CommissionRule/CommissionCalculation (generic, manually-entered
// figures). Not every product is commission-eligible and not every
// salesman gets the same products/rates - each row is one deliberate
// assignment, admin-picked.
model SalesmanProductCommission {
  id              Int       @id @default(autoincrement())
  organizationId  Int
  salesmanId      Int
  productId       Int
  commissionType  String    // PERCENTAGE | FIXED_PER_UNIT
  rate            Decimal   @db.Decimal(10, 2) // percentage value, or Rs per unit
  targetQuantity  Int       @default(0)
  periodStart     DateTime
  periodEnd       DateTime
  isActive        Boolean   @default(true)
  paidAt          DateTime?
  paidAmount      Int?
  journalEntryId  Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  salesman        User         @relation("SalesmanCommissionAssignments", fields: [salesmanId], references: [id])
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, salesmanId, productId, periodStart])
  @@index([organizationId, salesmanId])
  @@index([organizationId, productId])
}

// One row per uploaded CSV/XLS/XLSX sales report. reportStartDate/
// reportEndDate are derived from the transaction dates actually found in
// the file (not the file's own title text), so the upload-history UI can
// show which periods are covered and surface gaps between uploads.
model SalesAnalysisUpload {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  fileName        String
  uploadedBy      Int
  reportStartDate DateTime
  reportEndDate   DateTime
  rowCount        Int      @default(0)
  duplicateCount  Int      @default(0)
  conflictCount   Int      @default(0)
  status          String   @default("PROCESSED") // PROCESSED | FAILED
  errorMessage    String?
  createdAt       DateTime @default(now())

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser  User                  @relation(fields: [uploadedBy], references: [id])
  records         SalesAnalysisRecord[]

  @@index([organizationId, reportStartDate, reportEndDate])
}

// One row per parsed transaction line, deduplicated across uploads so that
// re-uploading an overlapping report never double-counts the same sale.
// (organizationId, billNumber, lineSequence) identifies "the Nth line item
// of bill X" - deliberately not keyed on quantity/price, since the same
// product can legitimately appear twice in one bill at the same price and
// that must not be flagged as a duplicate of itself.
model SalesAnalysisRecord {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  uploadId        Int
  billNumber      String
  lineSequence    Int
  transactionDate DateTime
  accountName     String?
  customerName    String?
  salesmanName    String?  // nullable - not every source report includes this
  itemRaw         String
  // Leading numeric code parsed from itemRaw (e.g. "123 Product Name" -> "123").
  // Deliberately NOT matched against this app's own Product.code - this whole
  // analysis suite is standalone and only ever cross-references two uploaded
  // datasets against each other (see PurchaseAnalysisRecord.productCode),
  // never this app's own Product/Vendor/GL tables.
  productCode     String?
  quantity        Decimal  @db.Decimal(12, 2)
  soldPrice       Decimal  @db.Decimal(12, 2)
  lineAmount      Decimal  @db.Decimal(14, 2)
  // Richer dimensions captured when the source file provides them (all
  // optional so older/simpler files still import). actualPrice is the list
  // price when the file distinguishes it from the discounted soldPrice.
  category        String?
  brand           String?
  warehouseName   String?
  actualPrice     Decimal? @db.Decimal(12, 2)
  paymentMethod   String?  // e.g. CASH / CREDIT
  // A return nets out of totals: quantity and lineAmount are stored NEGATIVE
  // for return rows, so every downstream aggregate reflects net-of-returns.
  isReturn        Boolean  @default(false)
  isDuplicate     Boolean  @default(false)
  // Normalized full item name (lowercased, whitespace collapsed) - the ONLY
  // sound key for cross-referencing a sale to its purchase cost. productCode
  // (the leading number) is a shelf/category code, NOT a product id: code
  // "176" alone covers 48 different purchase items priced Rs 2,175-41,800,
  // so joining on it costs a product against an unrelated one. Never use
  // productCode to resolve cost.
  itemKey         String?
  createdAt       DateTime @default(now())

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  upload          SalesAnalysisUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([organizationId, billNumber, lineSequence])
  @@index([organizationId, transactionDate])
  @@index([organizationId, salesmanName])
  @@index([organizationId, productCode])
  @@index([organizationId, accountName])
  @@index([organizationId, category])
  @@index([organizationId, brand])
  @@index([organizationId, itemKey])
}

// One row per uploaded purchase/vendor report - mirrors SalesAnalysisUpload
// exactly. Deliberately no link to this app's own Vendor table: vendorName
// is raw text from the file, since this whole analysis suite is standalone
// and only ever cross-references its own two uploaded datasets.
model PurchaseAnalysisUpload {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  fileName        String
  uploadedBy      Int
  reportStartDate DateTime
  reportEndDate   DateTime
  rowCount        Int      @default(0)
  duplicateCount  Int      @default(0)
  conflictCount   Int      @default(0)
  status          String   @default("PROCESSED") // PROCESSED | FAILED
  errorMessage    String?
  createdAt       DateTime @default(now())

  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser  User                     @relation(fields: [uploadedBy], references: [id])
  records         PurchaseAnalysisRecord[]

  @@index([organizationId, reportStartDate, reportEndDate])
}

// One row per parsed purchase line - mirrors SalesAnalysisRecord exactly,
// including the (organizationId, billNumber, lineSequence) dedupe key
// rationale. productCode uses the same leading-number parsing convention as
// SalesAnalysisRecord.productCode - that shared string is the only join key
// between sales and purchase data anywhere in this suite (see the profit
// cost-resolution query), never a real Product/Vendor id.
model PurchaseAnalysisRecord {
  id              Int      @id @default(autoincrement())
  organizationId  Int
  uploadId        Int
  billNumber      String
  lineSequence    Int
  transactionDate DateTime
  vendorName      String?
  itemRaw         String
  productCode     String?
  quantity        Decimal  @db.Decimal(12, 2)
  purchasePrice   Decimal  @db.Decimal(12, 2)
  lineAmount      Decimal  @db.Decimal(14, 2)
  isDuplicate     Boolean  @default(false)
  // Normalized full item name - the join key a sale uses to find its cost.
  // See SalesAnalysisRecord.itemKey for why productCode must never be used.
  itemKey         String?
  createdAt       DateTime @default(now())

  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  upload          PurchaseAnalysisUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([organizationId, billNumber, lineSequence])
  @@index([organizationId, transactionDate])
  @@index([organizationId, vendorName])
  @@index([organizationId, productCode])
  @@index([organizationId, itemKey, transactionDate])
}

// Juicers and blenders keep SEPARATE part catalogs on purpose: a generic
// component name like "Complete Body" means a genuinely different physical
// part (and a very different price, ~1000 vs ~145) between the two, so they
// must never merge into one shared part. Family is detected from the BOM
// itself - a "Jug Plastic" component means BLENDER, otherwise JUICER.
enum AssemblyFamily {
  JUICER
  BLENDER
}

// A shared raw part / labor line in the BOM catalog (Motor, Complete Body,
// Box, Labor, ...). ONE current unitCost per (family, name) - so changing a
// part's price ripples into every AssemblyFormula that uses it (the whole
// point of the tool). Where the source spreadsheets recorded the same part
// at different prices, hadPriceConflict flags it and conflictNote records
// what was seen, for the user to reconcile to a single correct current
// price. Deliberately NOT linked to the ERP's own inventory/Product tables.
model AssemblyPart {
  id               Int            @id @default(autoincrement())
  organizationId   Int
  family           AssemblyFamily
  name             String
  unitCost         Decimal        @db.Decimal(12, 2)
  hadPriceConflict Boolean        @default(false)
  conflictNote     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formulaLines     AssemblyFormulaLine[]

  @@unique([organizationId, family, name])
  @@index([organizationId, family])
}

// A model's BOM (juicer/blender variant). Its total cost is DERIVED at read
// time - sum(line.quantity x part.unitCost) - never stored, so it always
// reflects current shared part prices. `productCodes` is a best-effort
// '+'-split of the label kept for future ERP-product matching only.
// Freely re-editable config, so import upserts by label (later source
// wins) rather than the immutable-conflict logic the Sales/Purchase
// Analysis transaction tools use.
model AssemblyFormula {
  id             Int            @id @default(autoincrement())
  organizationId Int
  family         AssemblyFamily
  label          String
  // Free notes about this model - what it is, which variant, what to watch for.
  description    String?
  productCodes   String[]
  sourceFile     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          AssemblyFormulaLine[]
  assembledItems AssembledItemCost[]

  @@unique([organizationId, label])
  @@index([organizationId, family])
}

// Cost source for a model we ASSEMBLE rather than buy. Such an item appears
// in the purchase file only at price 0 (there is no real purchase to cost it
// against), so its cost comes from a BOM formula instead - and because the
// formula's cost is derived from the shared parts catalog, re-pricing one part
// re-costs every model that uses it. `manualCost` is the escape hatch when no
// formula fits. Mapping is user-confirmed, never auto-applied: the BOM labels
// name model families ("White Body 7025 Copper") while sales names carry brand
// prefixes ("1818 White Body 3in1 7025 Copper Philips"), so only the user can
// say which formula truly builds which product.
model AssembledItemCost {
  id             Int      @id @default(autoincrement())
  organizationId Int
  itemKey        String   // normalized sales item name (see SalesAnalysisRecord.itemKey)
  itemName       String   // as it appears in the sales file, for display
  formulaId      Int?
  manualCost     Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formula        AssemblyFormula? @relation(fields: [formulaId], references: [id], onDelete: SetNull)

  @@unique([organizationId, itemKey])
  @@index([organizationId])
  @@index([formulaId])
}

// One line of a formula: which shared part, and how many. quantity defaults
// to 1 (the source spreadsheets list each part once with no explicit qty;
// any embedded count like "Body Pech 6" stays baked into that part's name
// and price, not parsed out).
model AssemblyFormulaLine {
  id        Int     @id @default(autoincrement())
  formulaId Int
  partId    Int
  quantity  Decimal @default(1) @db.Decimal(10, 2)

  formula   AssemblyFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  part      AssemblyPart    @relation(fields: [partId], references: [id], onDelete: Restrict)

  @@unique([formulaId, partId])
  @@index([formulaId])
  @@index([partId])
}

// ============================================================================
// RECIPE ENGINE (the new, generic BOM — replaces the JUICER|BLENDER hardcoding)
// ============================================================================

// What a product IS. The recipe is the ground truth (a thing is a PART iff it
// appears in a recipe; MANUFACTURED iff it has one) - this stored type is the
// bootstrap classification and a display hint, never allowed to contradict the
// recipe graph.
enum ProductType {
  RAW_MATERIAL    // a stocked component you buy (Motor, Body, Box, Bolt)
  SERVICE         // has a cost, has no stock (Labour, Transport, Electricity)
  FINISHED_GOOD   // bought and resold as-is (the safe default)
  ASSEMBLED_GOOD  // you manufacture it from the above, via a Bom
}

// A recipe: makes ONE output product from other products. Versioned so that a
// completed manufacturing order can pin the exact recipe it used and keep its
// cost even after the recipe is later edited (Phase 2 freezes version + cost
// onto the batch).
model Bom {
  id             Int      @id @default(autoincrement())
  organizationId Int
  productId      Int      // the ASSEMBLED_GOOD this recipe makes
  name           String
  version        Int      @default(1)
  outputQuantity Decimal  @default(1) @db.Decimal(12, 3) // a recipe may yield N units
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product             Product              @relation("BomOutput", fields: [productId], references: [id], onDelete: Cascade)
  lines               BomLine[]
  manufacturingOrders ManufacturingOrder[]

  @@unique([organizationId, productId, version])
  @@index([organizationId, productId, isActive])
}

// One SLOT in a recipe: a generic role ("Motor", "Body", "Jug") filled by a
// specific chosen product, plus a quantity. Alternates are the other products
// valid in the same slot (7025 Copper vs 7030 vs 8820).
model BomLine {
  id                 Int     @id @default(autoincrement())
  bomId              Int
  sequence           Int     @default(0)
  slotName           String  // the generic term shown on screen: "Motor", "Body"
  componentProductId Int     // the CHOSEN product - always set, so cost always computes
  quantity           Decimal @default(1) @db.Decimal(12, 4) // 0.5 wire, 4 bolts

  bom        Bom                @relation(fields: [bomId], references: [id], onDelete: Cascade)
  component  Product            @relation("BomComponent", fields: [componentProductId], references: [id], onDelete: Restrict)
  alternates BomLineAlternate[]

  @@unique([bomId, slotName])
  @@index([bomId])
  @@index([componentProductId]) // powers "where is this part used?"
}

// Other products the user may pick for a slot without editing the recipe.
model BomLineAlternate {
  id        Int @id @default(autoincrement())
  bomLineId Int
  productId Int

  bomLine BomLine @relation(fields: [bomLineId], references: [id], onDelete: Cascade)
  product Product @relation("BomAlternate", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bomLineId, productId])
  @@index([bomLineId])
  @@index([productId])
}

// ============================================================================
// MANUFACTURING ORDER — where a recipe finally moves real stock (Phase 2).
// A recipe (Bom) only ever describes cost; this is the document that says
// "we actually built N of these on this date" and is the only thing that
// deducts components / adds the finished good.
// ============================================================================

enum ManufacturingOrderStatus {
  DRAFT        // planned; nothing has moved
  IN_PROGRESS  // material availability confirmed; ready to build
  COMPLETED    // stock moved: components out, finished good in - irreversible
  CANCELLED    // abandoned before completion; nothing ever moved
}

model ManufacturingOrder {
  id                Int      @id @default(autoincrement())
  organizationId    Int
  orderNumber       String                                  // the batch identity - "MO-2026-000001"
  bomId             Int                                      // the recipe used - Bom rows are
                                                               // immutable-once-superseded (new
                                                               // version = new row), so this FK alone
                                                               // pins the exact recipe this batch used
  finishedProductId Int                                      // denormalized from bom.productId
  warehouseId       Int
  quantityPlanned   Int
  quantityProduced  Int      @default(0)  // GOOD units (passed QC), added to finished stock
  // Units built but FAILED inspection - their components were consumed but they
  // never became sellable stock, so they are the yield loss. rejectReason says
  // why. Both set at completion.
  quantityRejected  Int      @default(0)
  rejectReason      String?
  status            ManufacturingOrderStatus @default(DRAFT)
  // FROZEN at COMPLETED, from quantityRequired x each line's cost snapshot -
  // never recomputed afterward, even if a component's price later changes.
  // This is the "what did THIS batch cost" the user explicitly needed, since
  // cost is not printed on the product itself.
  unitCostSnapshot  Decimal? @db.Decimal(12, 2)
  createdBy         Int
  completedBy       Int?
  completedAt       DateTime?
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bom             Bom                      @relation(fields: [bomId], references: [id])
  finishedProduct Product                  @relation("ManufacturingOrderOutput", fields: [finishedProductId], references: [id])
  warehouse       Warehouse                @relation(fields: [warehouseId], references: [id])
  lines           ManufacturingOrderLine[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model ManufacturingOrderLine {
  id                   Int      @id @default(autoincrement())
  manufacturingOrderId Int
  slotName             String                                // copied from BomLine at creation time
  componentProductId   Int
  quantityRequired     Decimal  @db.Decimal(12, 4)           // bomLine.quantity x quantityPlanned, frozen at creation
  // ACTUAL quantity used, entered at completion (defaults to quantityRequired
  // if nothing differed). scrap = quantityConsumed - quantityRequired -
  // measured after the fact, never a number typed into the recipe in advance.
  quantityConsumed     Decimal? @db.Decimal(12, 4)
  // component.cost_price AT CREATION, frozen. The counterpart to
  // unitCostSnapshot below: comparing the two is the price variance (component
  // price moved between planning the batch and building it). Nullable because
  // it was added in Phase 3, after some orders may already exist.
  plannedUnitCost      Decimal? @db.Decimal(12, 2)
  unitCostSnapshot     Decimal? @db.Decimal(12, 2)           // component.cost_price AT COMPLETION, frozen
  // Which received batch of this component went into the build (a
  // PurchaseOrderReceipt.batch_number). Recorded at completion for recall -
  // defective finished good -> the vendor batch its parts came from. Nullable:
  // a component with no received batch (e.g. pre-batch stock) reads as unknown.
  componentBatch       String?

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  component          Product            @relation("ManufacturingOrderLineComponent", fields: [componentProductId], references: [id])

  @@index([manufacturingOrderId])
}

// A remembered column-mapping for the format-agnostic importer. Keyed by a
// normalized signature of the file's header row, so a recurring export
// layout is auto-recognized and its confirmed mapping re-applied without
// the user re-mapping every time. `mapping` is canonicalField -> source
// column header (or index); `structure` is FLAT | MULTI_ROW.
model ImportMappingTemplate {
  id             Int      @id @default(autoincrement())
  organizationId Int
  module         String   // SALES | PURCHASE
  signature      String
  label          String
  structure      String   @default("FLAT")
  mapping        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, module, signature])
  @@index([organizationId, module])
}

// User-confirmed classification of a sales item name as a genuine SALE or a
// PART (a component supplied to vendors for assembly - boxes, handles, iron
// thermostat, Jug Glass, Jali, Nut Kaim, etc.). PART items are excluded from
// genuine sales/salesman/profit totals and shown in a separate parts report,
// their value subtracted from total sales. Candidates are pre-flagged by
// cross-referencing AssemblyPart names (NOT price), but the user confirms.
model SalesItemClassification {
  id             Int      @id @default(autoincrement())
  organizationId Int
  itemName       String
  kind           String   // PART | SALE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, itemName])
  @@index([organizationId, kind])
}
