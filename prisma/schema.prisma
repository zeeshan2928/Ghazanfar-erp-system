  invoiceId      Int
  salesmanId     Int

  commissionAmount     Int     @default(0) // in paisa
  commissionPercentage Decimal @db.Decimal(5, 2)

  invoiceTotal Int

  status String @default("PENDING") // PENDING, APPROVED, PAID

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Bill         @relation("InvoiceCommissions", fields: [invoiceId], references: [id], onDelete: Cascade)
  salesman     User         @relation("SalesmanCommissions", fields: [salesmanId], references: [id])

  @@index([salesmanId, status])
  @@index([invoiceId])
  @@index([organizationId, status])
}

model UserRoleAssignment {
