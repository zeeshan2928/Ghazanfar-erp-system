// Dedicated invoice-number counter, incremented atomically inside the same
// transaction as bill creation. Deliberately NOT derived from sorting/counting
// existing bill_number rows - that approach (used elsewhere in this codebase)
// broke in production on 2026-07-06 when inconsistent historical padding made
// a lexicographic sort pick the wrong "last" row and regenerate a duplicate.
// Format produced: INV-<currentBlock>-<currentCount padded to 5 digits>.
// currentBlock starts at 124 per the business's existing paper/legacy numbering
// and increments every 10,000 invoices (124 -> 125 -> 126 ...).
model InvoiceSequence {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  currentBlock   Int          @default(124)
  currentCount   Int          @default(0)
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Shared, reusable counter for auto-generated, non-editable transaction
// numbers across modules that don't already have their own (Bills use
// InvoiceSequence; GatePass/PurchaseOrder already generate their own
// numbers). One row per (organizationId, docType) - e.g. docType
// "JOURNAL_ENTRY" or "CASH_BOOK_ENTRY". Any manual reference a user enters
// (cashbookNumber, referenceNumber, etc.) stays a secondary, optional field
// alongside this - never the primary identifier.
model TransactionSequence {
  id             Int          @id @default(autoincrement())
  organizationId Int
  docType        String
  currentBlock   Int          @default(1)
  currentCount   Int          @default(0)
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, docType])
}

