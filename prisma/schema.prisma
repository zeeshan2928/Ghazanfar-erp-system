enum InvoiceApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum DocumentType {
  INVOICE
  GATE_PASS
  SALES_ORDER
  PURCHASE_ORDER
}

model InvoiceModification {
  id             Int @id @default(autoincrement())
  organizationId Int
  invoiceId      Int

  fieldName String
  oldValue  String?
  newValue  String?

  modifiedBy Int
  modifiedAt DateTime @default(now())

  approvalStatus InvoiceApprovalStatus @default(PENDING_APPROVAL)
  approvedBy     Int?
  approvedAt     DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Bill         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  modifiedByUser User         @relation("ModifiedBy", fields: [modifiedBy], references: [id])
  approvedByUser User?        @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@index([invoiceId, approvalStatus])
  @@index([modifiedBy, approvalStatus])
  @@index([approvedBy])
